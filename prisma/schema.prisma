generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // 👈 El motor clásico que lee tu .env automáticamente
}

// ==========================================
// 🏢 INFRAESTRUCTURA B2B (Páginas y Leads PYME)
// ==========================================

model LeadB2B {
  id        String        @id @default(cuid()) // O Int @default(autoincrement()) según lo tengas
  nombre    String
  email     String        @unique // El correo virtual que usamos de ancla
  empresa   String?       // Opcional por si no lo dan
  mensaje   String?       @db.Text
  estado    EstadoLeadB2B @default(NUEVO) // 🚨 Aplicamos el Enum aquí
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum EstadoLeadB2B {
  NUEVO
  CONTACTADO
  REUNION_AGENDADA
  PROPUESTA_ENVIADA
  CERRADO_GANADO
  CERRADO_PERDIDO
}

// ==========================================
// 🤖 INFRAESTRUCTURA B2C (Chatbot & Soporte Actual)
// ==========================================

model Cliente {
  id                 String    @id @default(uuid())
  nombre             String
  email              String?   @unique
  telefono           String    @unique
  createdAt          DateTime  @default(now())
  atendidoPorBot     Boolean   @default(true)
  googleChatThreadId String?   @unique
  mensajes           Mensaje[]
  tickets            Ticket[]

  @@index([telefono])
}

model Ticket {
  id               String       @id @default(uuid())
  numeroOrden      String       @unique
  equipo           String
  fallaReportada   String
  estado           EstadoTicket @default(RECIBIDO)
  costoEstimado    Float?
  notasInternas    String?
  clienteId        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  botActivo        Boolean      @default(true)
  costoReparacion  Float?
  notasDiagnostico String?
  citas            Cita[]
  cliente          Cliente      @relation(fields: [clienteId], references: [id])

  @@index([numeroOrden])
}

model Cita {
  id            String     @id @default(uuid())
  nombreCliente String
  telefono      String
  direccion     String
  distanciaKm   Float?
  coordenadas   String?
  fechaCita     DateTime
  tipo          TipoCita
  estado        EstadoCita @default(PENDIENTE)
  notas         String?
  ticketId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  ticket        Ticket?    @relation(fields: [ticketId], references: [id])

  @@index([telefono])
}

model Mensaje {
  id        String        @id @default(uuid())
  texto     String
  origen    OrigenMensaje @default(CLIENTE)
  clienteId String
  createdAt DateTime      @default(now())
  cliente   Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

model WebhookLog {
  id        String    @id
  createdAt DateTime? @default(now()) @db.Timestamp(6)
}

// ==========================================
// ⚙️ ENUMS REQUERIDOS
// ==========================================

enum OrigenMensaje {
  CLIENTE
  BOT
  HUMANO
}

enum TipoCita {
  RECOLECCION
  ENTREGA
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  EN_RUTA
  COMPLETADA
  CANCELADA
}

enum EstadoTicket {
  RECIBIDO
  EN_DIAGNOSTICO
  ESPERANDO_APROBACION
  EN_REPARACION
  LISTO_PARA_ENTREGA
  ENTREGADO
  RECHAZADO
}