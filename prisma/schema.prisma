generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELOS OPTIMIZADOS PARA EL CRM SOLTECOT_
// ==========================================

model Cliente {
  id                 String    @id @default(uuid())
  nombre             String
  email              String?   @unique 
  telefono           String    @unique 
  tickets            Ticket[] 
  mensajes           Mensaje[] // 💬 RELACIÓN INVERSA: Historial efímero conectado al cliente
  createdAt          DateTime  @default(now())

  // 🚨 CONTROL HÍBRIDO BOT / HUMANO (NUEVOS SUPERPODERES)
  atendidoPorBot     Boolean   @default(true)
  googleChatThreadId String?   @unique 

  @@index([telefono]) 
}

model Ticket {
  id               String       @id @default(uuid()) 
  numeroOrden      String       @unique 
  equipo           String       
  fallaReportada   String       
  estado           EstadoTicket @default(RECIBIDO)
  costoEstimado    Float?
  notasInternas    String?      
  clienteId        String
  cliente          Cliente      @relation(fields: [clienteId], references: [id])
  citas            Cita[]       
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  
  botActivo        Boolean      @default(true)
  costoReparacion  Float?
  notasDiagnostico String?

  @@index([numeroOrden]) 
}

model Cita {
  id            String     @id @default(uuid())
  nombreCliente String     
  telefono      String     
  direccion     String     
  distanciaKm   Float?     
  coordenadas   String?    
  fechaCita     DateTime   
  tipo          TipoCita   
  estado        EstadoCita @default(PENDIENTE)
  notas         String?    
  ticketId      String?  
  ticket        Ticket?    @relation(fields: [ticketId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([telefono])
}

// 💬 HISTORIAL EFÍMERO DE CHAT
// Se auto-elimina en cascada al cambiar el estatus a ENTREGADO o RECHAZADO
model Mensaje {
  id        String        @id @default(uuid())
  texto     String
  origen    OrigenMensaje @default(CLIENTE)
  clienteId String
  cliente   Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([clienteId])
}

enum OrigenMensaje {
  CLIENTE
  BOT
  HUMANO
}

enum TipoCita {
  RECOLECCION
  ENTREGA
}

enum EstadoCita {
  PENDIENTE     
  CONFIRMADA    
  EN_RUTA       
  COMPLETADA    
  CANCELADA     
}

enum EstadoTicket {
  RECIBIDO
  EN_DIAGNOSTICO
  ESPERANDO_APROBACION
  EN_REPARACION
  LISTO_PARA_ENTREGA
  ENTREGADO
  RECHAZADO 
}